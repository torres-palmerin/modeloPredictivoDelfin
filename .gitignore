# =============================================================
# .gitignore — Proyecto Modelo Predictivo (Estancia Delfín)
# =============================================================

# ---- Datos sensibles (NUNCA commitear datos de estudiantes) ----
data/
*.xlsx
*.xls
*.csv
*.parquet
*.sav

# ---- Modelos entrenados y artefactos pesados ----
*.pkl
*.joblib
*.pickle
*.h5
*.hdf5
models/
checkpoints/

# ---- Variables de entorno y credenciales AWS ----
.env
.env.*
.aws/
credentials
aws-credentials

# ---- Archivos Python ----
__pycache__/
*.py[cod]
*$py.class
*.so
*.egg-info/
dist/
build/
*.egg

# ---- Entornos virtuales ----
.venv/
venv/
env/
ENV/

# ---- Docker ----
.docker/
docker-compose.override.yml

# ---- IDE y editores ----
.vscode/
.idea/
*.swp
*.swo
*~
.DS_Store
Thumbs.db
desktop.ini

# ---- Logs ----
*.log
logs/

# ---- Jupyter Notebooks ----
.ipynb_checkpoints/

# ---- Cobertura de código y tests ----
.coverage
htmlcov/
.pytest_cache/
.mypy_cache/
.ruff_cache/

# ---- Despliegue Lambda ----
deployment_package.zip
*.zip

# ---- Streamlit ----
.streamlit/secrets.toml

# ---- Archivos del sistema ----
desktop.ini
