# =============================================================
# .gitignore — Proyecto Modelo Predictivo (Estancia Delfín)
# =============================================================

# ---- Datos sensibles (NUNCA commitear datos de estudiantes) ----
data/
*.xlsx
*.xls
*.csv
*.parquet
*.sav
*.pkl
*.joblib

# ---- Archivos Python ----
__pycache__/
*.py[cod]
*$py.class
*.so
*.egg-info/
dist/
build/
*.egg

# ---- Entornos virtuales ----
.venv/
venv/
env/
ENV/

# ---- IDE y editores ----
.vscode/
.idea/
*.swp
*.swo
*~
.DS_Store
Thumbs.db

# ---- Logs ----
*.log
logs/

# ---- Jupyter Notebooks ----
.ipynb_checkpoints/
*.ipynb_checkpoints

# ---- Modelos entrenados y artefactos ----
models/
*.joblib
*.pickle
checkpoints/

# ---- Variables de entorno ----
.env
.env.*

# ---- Cobertura de código y tests ----
.coverage
htmlcov/
.pytest_cache/
.mypy_cache/

# ---- Archivos del sistema ----
desktop.ini
